# ─────────────────────────────────────────────────────────────
#  Chess Backend — Environment Variables
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development

# Auth — secret used to sign login tokens (JWT). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Email for "forgot password" (optional). If unset, dev mode returns the
# reset link in the API response so you can still test it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Chess <no-reply@yourdomain.com>

# PostgreSQL connection string (Render provides this in the dashboard)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chess

# ── Billplz (use SANDBOX values while testing) ──────────────────
# Get these from your Billplz account: Settings > API Keys / Signature Key
BILLPLZ_API_URL=https://www.billplz-sandbox.com/api/v3
BILLPLZ_SECRET_KEY=your-billplz-api-secret-key
BILLPLZ_COLLECTION_ID=your-billplz-collection-id
# X-Signature Key — used to verify webhook & redirect authenticity
BILLPLZ_XSIGN_KEY=your-billplz-x-signature-key

# ── URLs ────────────────────────────────────────────────────────
# Public URL of THIS backend on Render (used to build the webhook callback)
BACKEND_PUBLIC_URL=https://your-app.onrender.com
# Your Vercel frontend URL (used for the post-payment redirect + CORS)
FRONTEND_URL=https://your-app.vercel.app
